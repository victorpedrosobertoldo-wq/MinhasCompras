<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MinhasCompras.Views.EditarProduto"
             Title="{Binding Descricao}">
    
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>


    <VerticalStackLayout Spacing="10">
        <Label Text="Descricao do Produto:"/>
        <Entry x:Name="DescricaoEntry" Text="{Binding Descricao}" Placeholder="Digite a descrição do produto"/>

        <Label Text="Quantidade:"/>
        <Entry x:Name="QuantidadeEntry" Text="{Binding Quantidade}" Placeholder="Digite a quantidade"/>

        <Label Text="Preço Unitario:"/>
        <Entry x:Name="PrecoUnitarioEntry" Text="{Binding Preco}" Placeholder="Digite o preço unitário"/>

        <Label Text="Categoria:"/>
        <Picker x:Name="picker_categoria"
        ItemDisplayBinding="{Binding Categoria}"/>
    </VerticalStackLayout>
</ContentPage>